# ─── Groww API Credentials ────────────────────────────────────
# Choose one authentication method:

# Method 1: API Key + Secret (requires daily approval on Groww Cloud API Keys page)
GROWW_API_KEY=your_api_key_here
GROWW_API_SECRET=your_api_secret_here

# Method 2: TOTP Flow (no expiry, recommendebut u said api ked)
GROWW_TOTP_TOKEN=eyJraWQiOiJaTUtjVXciLCJhbGciOiJFUzI1NiJ9.._KPzxl_4V9JtpXULwGWKmDQT7vTfA3Tm1hd0CyKLrB0C3em26sl-BEZU3pUHATxeJlBa8GHCcYP6g6T4Vam_fg
GROWW_TOTP_SECRET=QM4O6TASBTFOLOTMPIP6VI7LAYLYR4X5

# Authentication method: "api_key" or "totp"
GROWW_AUTH_METHOD=totp

# ─── Instruments ─────────────────────────────────────────────
# Comma-separated exchange tokens from:
# https://growwapi-assets.groww.in/instruments/instrument.csv
#
# Stocks: use numeric tokens (2885=Reliance, 14366=TCS, 11536=HDFC Bank)
# Indices: use names (NIFTY, BANKNIFTY, FINNIFTY, MIDCPNIFTY)
# System auto-detects and routes correctly.
SUBSCRIBE_INSTRUMENTS=2885,14366,11536,NIFTY,BANKNIFTY

# ─── Candle & Strategy ───────────────────────────────────────
# Timeframes to build candles (comma-separated: 1m,5m,15m,30m,1h,1d)
CANDLE_TIMEFRAMES=1m,5m

# SMA Crossover strategy parameters
SMA_FAST_PERIOD=5
SMA_SLOW_PERIOD=20

# ─── Paper Trading ───────────────────────────────────────────
# Quantity per trade
PAPER_QUANTITY=1

# Starting virtual balance
PAPER_STARTING_BALANCE=100000

# Max simultaneous open positions (0 = unlimited)
PAPER_MAX_POSITIONS=5

# ─── Reconnection ────────────────────────────────────────────
# Max reconnection attempts (0 = unlimited, keeps retrying)
RECONNECT_MAX_RETRIES=0

# ─── Telegram Alerts (REQUIRED) ───────────────────────────────
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8909449825:AAGDtDp-sUjj0YftVo2gWAvp1TOXjRKS6EI
# Get your chat ID from @userinfobot or @getidsbot
TELEGRAM_CHAT_ID=1655289022
# Portfolio summary interval in minutes (sent even if no trades happen)
TELEGRAM_SUMMARY_INTERVAL=30
# Control which events trigger notifications (true/false)
TELEGRAM_NOTIFY_SIGNALS=true
TELEGRAM_NOTIFY_POSITIONS=true
TELEGRAM_NOTIFY_RECONNECTS=true
TELEGRAM_NOTIFY_ERRORS=true

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
